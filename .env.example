# ─────────────────────────────────────────
# Serveur
# ─────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# Base de données
# ─────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/app_db
DATABASE_TEST_URL=postgres://postgres:password@localhost:5433/app_test_db
DATABASE_MAX_CONNECTIONS=10
DATABASE_ACQUIRE_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=600
DATABASE_MAX_LIFETIME=1800


# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=change_me_with_a_strong_random_secret
JWT_EXPIRATION=86400
JWT_REFRESH_SECRET=change_me_with_another_strong_random_secret
JWT_REFRESH_EXPIRATION=604800

# ─────────────────────────────────────────
# LOG
# ─────────────────────────────────────────
RUST_LOG=info,tower_http::trace::on_response=info,tower_http=off
